# GPU Inference Server (RunPod / Modal / Fal.ai)
# Set these in Vercel dashboard → Settings → Environment Variables
GPU_INFERENCE_URL=https://your-gpu-server.runpod.ai
GPU_API_SECRET=your-shared-secret-here

# GPU Backend (set on the RunPod/Modal container)
ALLOWED_ORIGINS=https://mlsystemsuniverse.com,http://localhost:3000
MODEL_NAME=default

# Pipeline mode: 'basic' (prompt-only) or 'spatial' (ControlNet + LoRA)
PIPELINE_MODE=basic
BASE_MODEL=stabilityai/stable-diffusion-2-1-base
LORA_WEIGHTS_PATH=

# LoRA Training (used with train_lora.py)
# TRIGGER_WORD=mystyle
